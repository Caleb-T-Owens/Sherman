<main>
  <h1>Dashboard</h1>

  <section>
    <h2>Welcome back, <%= Current.user.email_address %></h2>
    <p>You're all set up and ready to start using Life OS.</p>
  </section>

  <section>
    <h2>Accounting</h2>
    <nav>
      <ul>
        <li><%= link_to "Chart of Accounts", accounts_path %></li>
        <li><%= link_to "Transactions", transactions_path %></li>
        <li><%= link_to "Trial Balance", reports_trial_balance_path %></li>
        <li><%= link_to "Balance Sheet", reports_balance_sheet_path %></li>
        <li><%= link_to "Income Statement", reports_income_statement_path %></li>
      </ul>
    </nav>
  </section>

  <section>
    <h2>Account Information</h2>
    <dl>
      <dt>Email</dt>
      <dd><%= Current.user.email_address %></dd>
      <dt>Member Since</dt>
      <dd><%= Current.user.created_at.strftime("%B %d, %Y") %></dd>
    </dl>
  </section>
</main>
